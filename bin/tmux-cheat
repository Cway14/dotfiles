#!/bin/bash
# Description: Display a cheatsheet for tmux commands with Ctrl-a prefix

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

echo -e "${BOLD}${CYAN}🖥️  TMUX CHEATSHEET${NC}"
echo -e "${BOLD}${CYAN}==================${NC}"
echo -e "${YELLOW}Prefix key: ${BOLD}Ctrl-a (Caps Lock)${NC}"
echo ""

echo -e "${BOLD}${GREEN}📋 SESSIONS${NC}"
echo -e "${BLUE}tmux${NC}                    Start new session"
echo -e "${BLUE}tmux new -s name${NC}        Start new session with name"
echo -e "${BLUE}tmux ls${NC}                 List sessions"
echo -e "${BLUE}tmux attach -t name${NC}     Attach to session"
echo -e "${BLUE}tmux kill-session -t name${NC} Kill session"
echo -e "${PURPLE}Ctrl-a d${NC}              Detach from session"
echo -e "${PURPLE}Ctrl-a s${NC}              List/switch sessions"
echo -e "${PURPLE}Ctrl-a \$${NC}              Rename session"
echo ""

echo -e "${BOLD}${GREEN}🪟 WINDOWS${NC}"
echo -e "${PURPLE}Ctrl-a c${NC}              Create new window"
echo -e "${PURPLE}Ctrl-a ,${NC}              Rename window"
echo -e "${PURPLE}Ctrl-a &${NC}              Kill window"
echo -e "${PURPLE}Ctrl-a w${NC}              List windows"
echo ""

echo -e "${BOLD}${GREEN}🔄 SWITCHING WINDOWS${NC}"
echo -e "${PURPLE}Ctrl-a n${NC}              Next window"
echo -e "${PURPLE}Ctrl-a p${NC}              Previous window"
echo -e "${PURPLE}Ctrl-a l${NC}              Last window"
echo -e "${PURPLE}Ctrl-a 0-9${NC}            Switch to window by number"
echo -e "${PURPLE}Ctrl-a '${NC}              Prompt for window index"
echo -e "${PURPLE}Ctrl-a f${NC}              Find window by name"
echo ""

echo -e "${BOLD}${GREEN}📱 PANES${NC}"
echo -e "${PURPLE}Ctrl-a -${NC}              Split horizontally (pane below)"
echo -e "${PURPLE}Ctrl-a \\${NC}              Split vertically (pane right)"
echo -e "${PURPLE}Ctrl-a %${NC}              Split vertically (default)"
echo -e "${PURPLE}Ctrl-a \"${NC}              Split horizontally (default)"
echo -e "${PURPLE}Ctrl-a x${NC}              Kill pane"
echo -e "${PURPLE}Ctrl-a q${NC}              Show pane numbers"
echo -e "${PURPLE}Ctrl-a {${NC}              Move pane left"
echo -e "${PURPLE}Ctrl-a }${NC}              Move pane right"
echo -e "${PURPLE}Ctrl-a z${NC}              Toggle pane zoom"
echo -e "${PURPLE}Ctrl-a !${NC}              Break pane to window"
echo ""

echo -e "${BOLD}${GREEN}🔄 SWITCHING PANES${NC}"
echo -e "${PURPLE}Ctrl-a o${NC}              Next pane"
echo -e "${PURPLE}Ctrl-a ;${NC}              Last pane"
echo -e "${PURPLE}Ctrl-a ↑${NC}              Switch to pane above"
echo -e "${PURPLE}Ctrl-a ↓${NC}              Switch to pane below"
echo -e "${PURPLE}Ctrl-a ←${NC}              Switch to pane left"
echo -e "${PURPLE}Ctrl-a →${NC}              Switch to pane right"
echo -e "${PURPLE}Ctrl-a q [0-9]${NC}        Switch to pane by number"
echo ""

echo -e "${BOLD}${GREEN}🔧 RESIZE PANES${NC}"
echo -e "${PURPLE}Ctrl-a :${NC}              Enter command mode"
echo -e "${BLUE}:resize-pane -D${NC}        Resize down"
echo -e "${BLUE}:resize-pane -U${NC}        Resize up"
echo -e "${BLUE}:resize-pane -L${NC}        Resize left"
echo -e "${BLUE}:resize-pane -R${NC}        Resize right"
echo -e "${BLUE}:resize-pane -D 5${NC}      Resize down by 5"
echo ""

echo -e "${BOLD}${GREEN}📋 COPY MODE${NC}"
echo -e "${PURPLE}Ctrl-a [${NC}              Enter copy mode"
echo -e "${BLUE}Space${NC}                  Start selection"
echo -e "${BLUE}Enter${NC}                  Copy selection"
echo -e "${PURPLE}Ctrl-a ]${NC}              Paste"
echo -e "${BLUE}q${NC}                      Exit copy mode"
echo ""

echo -e "${BOLD}${GREEN}⚙️  CONFIGURATION${NC}"
echo -e "${PURPLE}Ctrl-a :${NC}              Command mode"
echo -e "${BLUE}:source-file ~/.tmux.conf${NC} Reload config"
echo -e "${BLUE}:list-keys${NC}             Show all key bindings"
echo -e "${BLUE}:list-commands${NC}         Show all commands"
echo ""

echo -e "${BOLD}${GREEN}🔍 USEFUL COMMANDS${NC}"
echo -e "${BLUE}tmux info${NC}              Show tmux info"
echo -e "${BLUE}tmux list-panes -a${NC}     List all panes"
echo -e "${BLUE}tmux capture-pane -p${NC}   Print pane contents"
echo -e "${BLUE}tmux display-message${NC}   Show current session info"
echo ""

echo -e "${YELLOW}💡 Tip: Press ${BOLD}Ctrl-a ?${NC}${YELLOW} in tmux to see all key bindings${NC}"